#     # shellcheck disable=SC2016
#     echo 'export PATH="$HOME/.pixi/bin:$PATH"' >> "$CLAUDE_ENV_FILE"
#     log "Persisted ~/.pixi/bin on PATH via CLAUDE_ENV_FILE."
#   fi
# fi

