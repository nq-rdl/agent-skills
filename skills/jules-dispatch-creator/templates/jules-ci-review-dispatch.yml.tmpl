# Template: Jules CI Review dispatch workflow.
#
# This template uses a `workflow_run` trigger — it fires automatically when a
# monitored CI workflow completes with a failure. It does NOT use issue_comment
# and does NOT require !contains guards against other @jules-* handles.
#
# Placeholders to replace before deploying:
#   [SECRET_NAME]         — GitHub Actions secret name for the Jules API key
#   [PROMPT CONTENT]      — repo-specific prompt (indented 12 spaces)
#   [CI_WORKFLOW_NAMES]   — JSON array of workflow name strings to monitor,
#                           e.g. ["Validate Skills", "Changelog Check"]
#
# Loop prevention: the `if` guard excludes the main branch and any branch
# starting with `jules/` (Jules's own fix branches) to prevent re-triggering.
# The concurrency group ensures only one Jules session runs per branch at a time.
name: Jules CI Review

on:
  workflow_run:
    workflows: [CI_WORKFLOW_NAMES]
    types: [completed]

jobs:
  fix-failure:
    runs-on: ubuntu-latest
    if: >
      github.event.workflow_run.conclusion == 'failure' &&
      github.event.workflow_run.head_branch != 'main' &&
      !startsWith(github.event.workflow_run.head_branch, 'jules/')
    concurrency:
      group: jules-ci-review-${{ github.event.workflow_run.head_branch }}
      cancel-in-progress: true
    permissions:
      contents: read
      actions: read
    steps:
      - name: Fetch failed job details
        id: failure
        uses: actions/github-script@v7
        with:
          script: |
            const jobs = await github.rest.actions.listJobsForWorkflowRun({
              owner: context.repo.owner,
              repo: context.repo.repo,
              run_id: context.payload.workflow_run.id,
            });
            const failed = jobs.data.jobs
              .filter(j => j.conclusion === 'failure')
              .map(j => j.name);
            core.setOutput('failed_jobs', failed.join(', '));
            core.setOutput('run_url', context.payload.workflow_run.html_url);

      - name: Invoke Jules — CI Failure Fix
        uses: nq-rdl/jules-action@d8ed19ed75a6c2a35fd4e06e5b2ca7cd68b27046  # pinned 2026-04-02
        with:
          jules_api_key: ${{ secrets.[SECRET_NAME] }}
          starting_branch: ${{ github.event.workflow_run.head_branch }}
          include_commit_log: true
          require_plan_approval: false
          title: "CI Fix: ${{ github.event.workflow_run.name }} on ${{ github.event.workflow_run.head_branch }}"
          prompt: |
            [PROMPT CONTENT]
