diff --git a/catalog/environment_test.go b/catalog/environment_test.go
new file mode 100644
index 0000000..9a273ae
--- /dev/null
+++ b/catalog/environment_test.go
@@ -0,0 +1,18 @@
+package catalog
+
+import "testing"
+
+func TestEnvironments(t *testing.T) {
+	envs := Environments()
+	providers := Providers()
+	packages := Packages()
+	if len(envs) != 1 {
+		t.Fatalf("len = %d, want 1", len(envs))
+	}
+	if envs[0].Provider != providers[0].Name {
+		t.Fatalf("provider = %q, want %q", envs[0].Provider, providers[0].Name)
+	}
+	if envs[0].Package != packages[0].Name {
+		t.Fatalf("package = %q, want %q", envs[0].Package, packages[0].Name)
+	}
+}
