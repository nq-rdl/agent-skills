+package catalog
+
+import "testing"
+
+func TestProviders(t *testing.T) {
+	got := Providers()
+	if len(got) != 2 {
+		t.Fatalf("len = %d, want 2", len(got))
+	}
+	if got[0].Name != "claude" {
+		t.Fatalf("first provider = %q, want claude", got[0].Name)
+	}
+}
