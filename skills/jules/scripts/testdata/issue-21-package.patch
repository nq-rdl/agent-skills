@@ -0,0 +1,13 @@
+package catalog
+
+import "testing"
+
+func TestPackages(t *testing.T) {
+	got := Packages()
+	if len(got) != 2 {
+		t.Fatalf("len = %d, want 2", len(got))
+	}
+	if got[0].Provider != "claude" {
+		t.Fatalf("first package provider = %q, want claude", got[0].Provider)
+	}
+}
