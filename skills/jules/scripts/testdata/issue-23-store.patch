@@ -0,0 +1,14 @@
+package catalog
+
+import "testing"
+
+func TestStores(t *testing.T) {
+	stores := Stores()
+	envs := Environments()
+	if len(stores) != 1 {
+		t.Fatalf("len = %d, want 1", len(stores))
+	}
+	if stores[0].Environment != envs[0].Name {
+		t.Fatalf("environment = %q, want %q", stores[0].Environment, envs[0].Name)
+	}
+}
